# Supabase — obrigatório
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# URL da aplicação (usado para redirect OAuth do Google)
VITE_APP_URL=http://localhost:5173

# ============================================================
# ATENÇÃO: As chaves das IAs (Groq, Gemini) NÃO devem ficar
# no frontend. Adicione-as como Secrets nas Edge Functions do
# Supabase:
#   supabase secrets set GROQ_API_KEY=...
#   supabase secrets set GEMINI_API_KEY=...
#   supabase secrets set ABACATEPAY_API_KEY=...
#   supabase secrets set ABACATEPAY_WEBHOOK_SECRET=...
#   supabase secrets set ALLOWED_ORIGIN=https://canadapath.ai
# ============================================================
